{
  "name": "buildable/serializer-bundle",
  "version": "1.0.0",
  "description": "Build-time optimized Symfony Serializer normalizer generation",
  "type": "symfony-bundle",
  "license": "MIT",
  "require": {
    "php": "8.1.*",
    "symfony/config": "^6.4",
    "symfony/console": "^6.4",
    "symfony/dependency-injection": "^6.4",
    "symfony/finder": "^6.4",
    "symfony/http-kernel": "^6.4",
    "symfony/property-access": "^6.4",
    "symfony/property-info": "^6.4",
    "symfony/serializer": "^6.4",
    "symfony/yaml": "^6.4"
  },
  "require-dev": {
    "carthage-software/mago": "^1.18",
    "phpdocumentor/reflection-docblock": "^5.2",
    "phpdocumentor/type-resolver": "^1.7",
    "phpstan/phpstan": "^1.10",
    "phpstan/phpstan-symfony": "^1.3",
    "phpunit/phpunit": "^10.0",
    "symfony/framework-bundle": "^6.4",
    "symfony/phpunit-bridge": "^6.4"
  },
  "autoload": {
    "psr-4": {
      "Buildable\\SerializerBundle\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Buildable\\SerializerBundle\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": true
    }
  },
  "extra": {
    "symfony": {
      "require": "^6.4"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite=Unit",
    "test:integration": "phpunit --testsuite=Integration",
    "test:coverage": "phpunit --coverage-text",
    "phpstan": "phpstan analyse src tests",
    "mago": "mago format"
  }
}
